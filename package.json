{
  "name": "dynt",
  "version": "0.5.0",
  "private": true,
  "description": "Independent formation and kinetic engines for framework-agnostic interfaces.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aibolt/dynt.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present && npm run build:examples",
    "build:examples": "esbuild examples/framework-browser/app.jsx --bundle --format=esm --minify --outfile=examples/framework-browser/bundle.js",
    "test": "npm run test --workspaces --if-present && node --test test/*.test.mjs",
    "test:browser": "playwright test",
    "test:packages": "npm run build && node scripts/verify-packages.mjs",
    "publish:packages": "node scripts/publish-packages.mjs",
    "verify:release-version": "node scripts/verify-release-version.mjs"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "esbuild": "0.28.1"
  },
  "engines": {
    "node": ">=20"
  }
}
