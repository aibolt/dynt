    },
    "@dynt/kinetic": {
      "optional": true
    }
  },
  "devDependencies": {
    "@dynt/formation": "0.5.0",
    "@dynt/kinetic": "0.5.0",
    "happy-dom": "20.10.6",
    "typescript": "5.9.3"
