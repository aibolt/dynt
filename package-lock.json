{
  "name": "dynt",
  "version": "0.0.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "dynt",
      "version": "0.0.0",
      "workspaces": [
        "packages/*"
      ],
      "engines": {
        "node": ">=20"
      }
    },
    "node_modules/@dynt/formation": {
      "resolved": "packages/formation",
      "link": true
    },
    "node_modules/@dynt/kinetic": {
      "resolved": "packages/kinetic",
      "link": true
    },
    "packages/formation": {
      "name": "@dynt/formation",
      "version": "0.0.0"
    },
    "packages/kinetic": {
      "name": "@dynt/kinetic",
      "version": "0.0.0"
    }
  }
}
